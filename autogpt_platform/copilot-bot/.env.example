# ── AutoGPT Platform API ──────────────────────────────────────────────
# URL of the running AutoGPT backend
AUTOGPT_API_URL=http://localhost:8006

# Service API key — must match PLATFORM_BOT_API_KEY on the backend
PLATFORM_BOT_API_KEY=your-secret-key-here

# ── Vercel / Webhook URL ──────────────────────────────────────────────
# Public URL where this service is deployed (used to build webhook URLs)
WEBHOOK_BASE_URL=https://your-bot.vercel.app

# Secret for protecting the gateway cron endpoint (generate with: openssl rand -hex 32)
CRON_SECRET=your-cron-secret-here

# ── Discord ───────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_PUBLIC_KEY=your-discord-public-key
DISCORD_APPLICATION_ID=your-discord-application-id
# Optional: comma-separated role IDs that can trigger bot mentions
# DISCORD_MENTION_ROLE_IDS=1234567890,0987654321

# ── Telegram ──────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── Slack ─────────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=your-slack-bot-token
# SLACK_SIGNING_SECRET=your-slack-signing-secret
# SLACK_APP_TOKEN=your-slack-app-token

# ── State ─────────────────────────────────────────────────────────────
# Use Redis in production so state survives across serverless instances.
# Without this, bot state resets on every cold start.
# REDIS_URL=redis://localhost:6379
